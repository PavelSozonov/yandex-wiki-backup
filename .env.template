# URL of the root wiki page to back up
WIKI_ROOT_URL=

# Optional login URL for automatic form-based login
LOGIN_URL=

# Credentials for form-based login
USERNAME=
PASSWORD=

# Alternatively, provide session cookies to skip login
# Example: "sessionid=abc123; othercookie=value"
COOKIE_STRING=

# Output directory inside the container
OUTPUT_DIR=/app/output

# Set to 'false' to show the browser for manual login
HEADLESS=true
