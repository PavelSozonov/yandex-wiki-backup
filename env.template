# Конфигурация Yandex Wiki Backup

# URL вашей wiki (обязательный параметр)
WIKI_URL=https://wiki.yandex-team.ru

# Метод аутентификации: "cookie" или "credentials"
AUTH_METHOD=cookie

# Cookie для аутентификации (используется если AUTH_METHOD=cookie)
# Получите cookie из браузера в Developer Tools -> Network -> Cookie header
COOKIE=your_cookie_string_here

# Учетные данные Yandex (используется если AUTH_METHOD=credentials)
USERNAME=your_username
PASSWORD=your_password

# Директория для сохранения результата (по умолчанию: output)
OUTPUT_DIR=output

# Игнорировать ошибки SSL сертификатов (true/false)
IGNORE_SSL_ERRORS=true 